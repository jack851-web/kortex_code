    <texture type="2d" name="cup0" file="visual/image0.png" />
    <material name="m_cup" texture="cup0" specular="0.5" shininess="0.359999993" />
  </asset>

  <worldbody>
    <body name="body_obj_cup">
      <freejoint />
      <body name="object_cup">
        <!-- 视觉mesh -->
        <geom type="mesh" mesh="cup_normalized_0_vis" conaffinity="0" contype="0" group="2" material="m_cup" />

        <!-- 空心杯壁：用更粗的半圆柱环绕，增加接触稳定性 -->
        <!-- 半径 15mm，壁厚 30mm，确保和夹爪有足够接触面 -->
        <geom name="cup_wall_front" type="cylinder" size="0.015 0.055" pos="0.032 0 0" euler="0 1.5708 0"
              solimp="0.95 0.99 0.001" solref="0.008 1"
              density="350" friction="1.8 0.005 0.001"
              rgba="0.8 0.8 0.8 0.15" group="3" />
        <geom name="cup_wall_back" type="cylinder" size="0.015 0.055" pos="-0.032 0 0" euler="0 1.5708 0"
              solimp="0.95 0.99 0.001" solref="0.008 1"
              density="350" friction="1.8 0.005 0.001"
              rgba="0.8 0.8 0.8 0.15" group="3" />
        <geom name="cup_wall_left" type="cylinder" size="0.015 0.055" pos="0 0.032 0" euler="1.5708 0 0"
              solimp="0.95 0.99 0.001" solref="0.008 1"
              density="350" friction="1.8 0.005 0.001"
              rgba="0.8 0.8 0.8 0.15" group="3" />
        <geom name="cup_wall_right" type="cylinder" size="0.015 0.055" pos="0 -0.032 0" euler="1.5708 0 0"
              solimp="0.95 0.99 0.001" solref="0.008 1"
              density="350" friction="1.8 0.005 0.001"
              rgba="0.8 0.8 0.8 0.15" group="3" />

        <!-- 杯底 -->
        <geom name="cup_bottom" type="cylinder" size="0.028 0.004" pos="0 0 -0.055"
              solimp="0.95 0.99 0.001" solref="0.008 1"
              density="350" friction="1.8 0.005 0.001"
              rgba="0.7 0.7 0.7 0.15" group="3" />
      </body>

      <site rgba="0 0 0 0" size="0.005" pos="0 0 -0.05" name="bottom_site_cup" />
      <site rgba="0 0 0 0" size="0.005" pos="0 0 0.055" name="top_site_cup" />
      <site rgba="0 0 0 0" size="0.005" pos="0.04 0.04 0" name="horizontal_radius_site_cup" />
