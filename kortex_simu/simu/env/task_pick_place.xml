<mujoco model="pick_place_task">
  <!-- 物理仿真参数优化 -->
  <option integrator="RK4" noslip_iterations="20"
          timestep="0.001" gravity="0 0 -9.81"
          cone="pyramidal" impratio="10" o_margin="0.001"/>

  <size memory="500M"/>

  <default>
    <joint armature="0.1" damping="0.1"/>
    <default class="visual_only">
      <geom type="mesh" contype="0" conaffinity="0" group="2"/>
    </default>
    <default class="no_visual_collision">
      <geom type="capsule" solimp=".9 .99 .001" solref=".015 1" group="3"/>
    </default>
    <default class="visual_collision">
      <geom type="mesh" solimp=".9 .99 .001" solref=".015 1" group="2"/>
    </default>
    <default class="object">
      <joint armature="0.02" damping="2.0"/>
      <geom rgba="0.2 0.8 0.2 1" density="100" friction="2.0 0.1 0.1" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </default>
  </default>

  <compiler angle="radian" coordinate="local"/>

  <!-- 机械臂：基座位于 (0, 0, 0.02) -->
  <include file="../robot/gen3_lite_gen3_lite_2f.xml"/>

  <!-- 场景资源 -->
  <asset>
    <!-- 天空 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <!-- 地板 -->
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.9 0.9 0.9" rgb2="0.8 0.8 0.8" markrgb="0.8 0.8 0.8" width="1000" height="1000"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="1 1" reflectance="0.1"/>
    <!-- 木桌 -->
    <texture type="2d" name="light_wood" file="mesh/light_wood_v3.png"/>
    <material name="wood_table_mat" texture="light_wood" specular="0.5" shininess="0.5" rgba="0.5 0.5 0.5 1"/>

    <!-- 动态物体资源占位 -->
    <!-- DYNAMIC_OBJECT_ASSET -->
    <!-- PLATE_OBJECT_ASSET -->
  </asset>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>
    <!-- 光照 -->
    <light pos="1 -1 1.5" dir="-1 1 -1" diffuse="0.5 0.5 0.5" directional="true"/>
    <light pos="-1 1 2" dir="1 -1 -1" diffuse="0.3 0.3 0.3" directional="true"/>

    <!-- 地板：位于机械臂基座下方 -->
    <geom name="floor" group="1" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- 木桌：body 在原点，桌面向前伸出
         Gen3 Lite 可达半径约 0.55m，桌面应在机械臂前方
         桌面实际中心：x=0.35, y=0, z=0.42
         桌面覆盖：x ∈ [-0.15, 0.85], y ∈ [-0.35, 0.35]
    -->
    <body name="front_object_table" pos="0 0 0" euler="0 0 0">
      <geom name="front_object_table" size="0.5 0.35 0.02" pos="0.35 0 0.42" type="box"
            material="wood_table_mat" contype="1" conaffinity="1"/>
      <!-- 桌腿 -->
      <geom name="table_leg_fl" type="cylinder" size="0.025 0.21" pos="0.80 0.30 0.21" rgba="0.4 0.3 0.2 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_fr" type="cylinder" size="0.025 0.21" pos="0.80 -0.30 0.21" rgba="0.4 0.3 0.2 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_bl" type="cylinder" size="0.025 0.21" pos="-0.10 0.30 0.21" rgba="0.4 0.3 0.2 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_br" type="cylinder" size="0.025 0.21" pos="-0.10 -0.30 0.21" rgba="0.4 0.3 0.2 1" contype="1" conaffinity="1"/>
      <inertial pos="0 0 0" mass="1" diaginertia="0 0 0"/>
    </body>

    <!-- 动态物体占位：运行时由任务配置注入 -->
    <!-- DYNAMIC_OBJECT_BODY -->

    <!-- 放置目标标记：在桌面上，机械臂可达范围内 -->
    <site name="place_target" pos="0.25 0 0.44" size="0.01" rgba="1 0 0 1"/>

    <!-- 静态放置目标占位（碟子） -->
    <!-- PLATE_OBJECT_BODY -->

    <!-- 相机：相对于桌子定位
         agentview：桌子正上方俯视
         top：正上方大视野
         side：侧面观察
         hand：手眼视角
    -->
    <body name="cam_agentview" pos="0.35 0 1.2" euler="0 0 0">
      <camera name="agentview" fovy="60" pos="0 0 0" xyaxes="0 1 0 -0.3 0 0.9"/>
    </body>

    <body name="cam_top" pos="0.35 0 2.0" euler="0 0 0">
      <camera name="top" fovy="90" pos="0 0 0" xyaxes="0 -1 0 1 0 0"/>
    </body>

    <body name="cam_side" pos="0.35 -0.8 1.0" euler="0 0 0">
      <camera name="side" fovy="90" pos="0 0 0" xyaxes="1 0 0 0 0 1"/>
    </body>

    <body name="cam_hand" pos="0.6 0 1.5" euler="0 0 0">
      <camera name="robot0_eye_in_hand" fovy="60" pos="0 0 0" xyaxes="0 1 0 -0.3 0 0.9"/>
    </body>
  </worldbody>
</mujoco>